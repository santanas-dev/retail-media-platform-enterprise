{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rmp.internal/contracts/proof-event/v1",
  "title": "Proof Event v1",
  "description": "Pilot proof-of-play event schema — flat structure matching PopEventIn DTO. Nested structure deferred to v2 if needed.",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "device_id",
    "creative_asset_id",
    "surface_id",
    "duration_ms",
    "playback_result",
    "rendered_at",
    "event_recorded_at"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "event_type": { "type": "string", "const": "proof" },
    "schema_version": { "type": "string", "const": "1.0" },
    "device_id": { "type": "string", "minLength": 1 },
    "manifest_id": { "type": ["string", "null"] },
    "campaign_id": { "type": ["string", "null"] },
    "creative_asset_id": { "type": "string", "minLength": 1 },
    "surface_id": { "type": "string", "minLength": 1 },
    "duration_ms": { "type": "integer", "minimum": 1, "maximum": 86400000 },
    "playback_result": {
      "type": "string",
      "enum": ["success", "fallback", "interrupted", "failed"]
    },
    "rendered_at": { "type": "string", "format": "date-time" },
    "event_recorded_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "not": {
    "anyOf": [
      { "required": ["storage_bucket"] },
      { "required": ["storage_key"] },
      { "required": ["access_key"] },
      { "required": ["secret_key"] }
    ]
  }
}
